# Django Settings
DJANGO_SECRET_KEY=your-secret-key-here-generated-by-render
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=.onrender.com

# Database (Render PostgreSQL)
# This will be auto-populated when you link the PostgreSQL service
DATABASE_URL=postgresql://user:password@host:port/database

# Twilio Settings (get from https://www.twilio.com/console)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# Python Version (matching render.yaml)
PYTHON_VERSION=3.12.3
